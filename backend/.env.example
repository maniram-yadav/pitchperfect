PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pitchperfect
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
OPENAI_API_KEY=your_openai_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ──────────────────────────────────────────────
# PayU Payment Gateway
# Get credentials from: https://onboarding.payu.in/app/account/merchant-details
#
# PAYU_TEST_MODE=true  → uses https://test.payu.in/_payment
# PAYU_TEST_MODE=false → uses https://secure.payu.in/_payment
#
# Test credentials (sandbox):
#   Key:  gtKFFx
#   Salt: eCwWELxi
# ──────────────────────────────────────────────
PAYU_MERCHANT_KEY=your_payu_merchant_key
PAYU_MERCHANT_SALT=your_payu_merchant_salt
PAYU_TEST_MODE=true

# Public URL of this backend — used to build PayU surl/furl callback URLs.
# In Cloud Run: https://YOUR_SERVICE-HASH-REGION.run.app
BACKEND_URL=http://localhost:5000

# ──────────────────────────────────────────────
# PostgreSQL — Google Cloud SQL
#
# Option A: Cloud SQL Auth Proxy (recommended for Cloud Run / GKE)
#   Set CLOUD_SQL_SOCKET_PATH and leave POSTGRES_HOST empty.
#   The proxy must be running alongside the app.
#   CLOUD_SQL_SOCKET_PATH=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME
#
# Option B: Direct TCP (public IP with SSL, or private IP from VPC)
#   Leave CLOUD_SQL_SOCKET_PATH empty and set POSTGRES_HOST / POSTGRES_SSL.
# ──────────────────────────────────────────────
CLOUD_SQL_SOCKET_PATH=/cloudsql/YOUR_PROJECT:us-central1:pitchperfect-db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DATABASE=pitchperfect
POSTGRES_SSL=false
POSTGRES_POOL_SIZE=10

# ──────────────────────────────────────────────
# Webhook
# WEBHOOK_SECRET secures POST /api/webhook/payment via HMAC-SHA256.
# Set to any strong random string (32+ chars).
# Leave empty to skip signature verification in development.
# The payment gateway must send this in the X-Webhook-Signature header
# as a lowercase hex HMAC-SHA256 of the raw request body.
# ──────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_secret_here

# ──────────────────────────────────────────────
# Email Strategy
# Supported values: smtp | oauth2
# smtp   → uses GMAIL_APP_PASSWORD (simple, works for personal Gmail)
# oauth2 → uses Google Cloud OAuth2 credentials (for Workspace / production)
# ──────────────────────────────────────────────
EMAIL_STRATEGY=smtp

GMAIL_USER=your_gmail@gmail.com

# smtp strategy (EMAIL_STRATEGY=smtp)
GMAIL_APP_PASSWORD=your_16_char_app_password

# oauth2 strategy (EMAIL_STRATEGY=oauth2)
# Get these from Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Contact form — email address that receives contact form submissions
CONTACT_EMAIL=your_admin_email@gmail.com

