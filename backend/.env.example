PORT=5000
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pitchperfect
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
OPENAI_API_KEY=your_openai_api_key
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ──────────────────────────────────────────────
# Email Strategy
# Supported values: smtp | oauth2
# smtp   → uses GMAIL_APP_PASSWORD (simple, works for personal Gmail)
# oauth2 → uses Google Cloud OAuth2 credentials (for Workspace / production)
# ──────────────────────────────────────────────
EMAIL_STRATEGY=smtp

GMAIL_USER=your_gmail@gmail.com

# smtp strategy (EMAIL_STRATEGY=smtp)
GMAIL_APP_PASSWORD=your_16_char_app_password

# oauth2 strategy (EMAIL_STRATEGY=oauth2)
# Get these from Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_client_id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your_client_secret
GMAIL_REFRESH_TOKEN=your_refresh_token
NODE_ENV=development

